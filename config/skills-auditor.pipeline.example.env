# Skills Auditor — optional pipeline config
# Copy to a private path (e.g. ~/.config/skills-auditor/pipeline.env), adjust, then:
#   set -a && source ~/.config/skills-auditor/pipeline.env && set +a

# Space-separated skill roots; agents expand each token to repeated --skills-dir
SKILLS_AUDITOR_ROOTS="$HOME/.cursor/skills $HOME/.claude/skills"

# Optional extra roots (e.g. monorepo .cursor/skills)
# SKILLS_AUDITOR_EXTRA_ROOTS="/path/to/repo/.cursor/skills"

# 1 = pass --with-drift on discover and close audits
SKILLS_AUDITOR_WITH_DRIFT=1

# Pipeline width: full (default) | discover | dedup | route | traces | sync | close
SKILLS_AUDITOR_MODE=full

# Route phase: comma-separated platform ids
SKILLS_AUDITOR_ROUTE_PLATFORMS=cursor,codex

# archive | delete | keep
SKILLS_AUDITOR_ROUTE_STRATEGY=archive

# If set and non-empty, cycle 5 runs sync with this map file
# SKILLS_AUDITOR_SYNC_MAP_FILE=/absolute/path/to/sources.json

# SKILLS_AUDITOR_CONFIG=$HOME/.config/skills-auditor/pipeline.env

# 1 = plan only (no --apply on dedup / route / sync). Unset or 0 = apply (top skill default).
# SKILLS_AUDITOR_DRY_RUN=0
